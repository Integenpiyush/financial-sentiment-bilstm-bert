        "from collections import Counter\n",
        "import re\n",
        "\n",
        "def get_top_words(df, sentiment, n=15):\n",
        "    text = ' '.join(df[df['sentiment']==sentiment]['text'])\n",
        "    # Remove punctuation and lowercase\n",
        "    text = re.sub(r'[^\\w\\s]', '', text.lower())\n",
        "    words = text.split()\n",
        "    # Remove common stopwords manually\n",
        "    stopwords = {'the', 'a', 'an', 'and', 'or', 'but', 'in',\n",
        "                 'on', 'at', 'to', 'for', 'of', 'with', 'by',\n",
        "                 'from', 'is', 'was', 'are', 'were', 'be',\n",
        "                 'has', 'have', 'had', 'its', 'it', 'this',\n",
        "                 'that', 'will', 'would', 'could', 'their',\n",
        "                 'than', 'as', 'not', 'also', 'which', 'been'}\n",
        "    words = [w for w in words if w not in stopwords and len(w) > 2]\n",
        "    return Counter(words).most_common(n)\n",
        "\n",
        "print(\"Top 15 words â POSITIVE:\")\n",
        "print(get_top_words(df, 'positive'))\n",
        "\n",
        "print(\"\\nTop 15 words â NEGATIVE:\")\n",
        "print(get_top_words(df, 'negative'))\n",
        "\n",
        "print(\"\\nTop 15 words â NEUTRAL:\")\n",
        "print(get_top_words(df, 'neutral'))"
      ],
